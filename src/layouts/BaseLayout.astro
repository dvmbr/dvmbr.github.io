---
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const { title = "DVMBR Portfolio", description = "DVMBR Portfolio" } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <slot />
  </body>
</html>
