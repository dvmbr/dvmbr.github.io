---
import RootLayout from "@/layouts/RootLayout.astro";
import ProjectPagination from "@/components/projects/ProjectPagination";
---

<RootLayout>
  <!-- page wrapper -->
  <div class="font-custom">
    <!-- hero -->
    <section class="typo-content container mx-auto px-4 py-24">
      <div class="flex justify-center">
        <div class="max-w-3xl text-center">
          <h1>
            I build on the web — experimenting, creating, and contributing
          </h1>

          <p class="mt-6 text-lg!">
            A web developer who enjoys trying ideas and turning them into real
            things.
          </p>
        </div>
      </div>
    </section>
    <!-- //hero -->

    <!-- projects -->
    <section class="typo-content container mx-auto px-4 py-16">
      <div class="mb-10">
        <h2>Projects</h2>
        <p class="mt-3 text-lg!">
          Selected work focused on structure, flow, and practical
          problem-solving.
        </p>
      </div>

      <ProjectPagination client:load />
    </section>
    <!-- //projects -->
  </div>

  <!-- //page wrapper -->
</RootLayout>
