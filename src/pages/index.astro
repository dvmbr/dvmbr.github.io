---
import RootLayout from "@/layouts/RootLayout.astro";
import ProjectPagination from "@/components/projects/ProjectPagination";
---

<RootLayout>
  <!-- page wrapper -->
  <div class="font-custom">
    <!-- hero -->
    <section class="typo-content container mx-auto h-dvh px-4 py-24">
      <div class="flex h-full items-center justify-center">
        <div class="animate-fade-up max-w-3xl text-center">
          <h1>
            I build on the web — experimenting, creating, and contributing
          </h1>

          <p class="mt-12 text-xl!">
            A web developer who enjoys trying ideas and turning them into real
            things.
          </p>
        </div>
      </div>
    </section>
    <!-- //hero -->

    <!-- projects -->
    <section class="typo-content container mx-auto px-4 py-16">
      <div class="mb-10">
        <h2>Projects</h2>
        <p class="mt-3 text-lg!">
          Selected work focused on structure, flow, and practical
          problem-solving.
        </p>
      </div>

      <ProjectPagination client:load />
    </section>
    <!-- //projects -->

    <!-- about me -->
    <section class="typo-content container mx-auto px-4 py-16">
      <div class="mb-10">
        <h2>About Me</h2>
        <p class="mt-3 text-lg!">
          How I think about building, experimenting, and creating on the web.
        </p>
      </div>

      <article class="mx-auto max-w-3xl space-y-6">
        <p>
          I am a web developer who enjoys experimenting with ideas and turning
          them into working structures on the web. Through exploring new
          approaches and trying different possibilities, I focus on going beyond
          simple implementation and creating outcomes in my own way.
        </p>

        <p>
          Rather than just building features, I consider user flows and
          operational contexts to create more stable and maintainable solutions.
          In live services, I have designed and improved web app interfaces
          around key flows such as orders and settlements, continuously refining
          structures while resolving recurring issues.
        </p>

        <p>
          I have also worked on a variety of projects, including invite-based
          entry systems, dashboards, and automation tools. Across these, I focus
          not only on implementation, but on designing the flow and connections
          between features. Throughout the process, I consistently think about
          how what I build is actually used and what kind of value it creates.
        </p>

        <p>
          I enjoy experimenting and building my own creations, and I aim to
          ensure that what I create goes beyond a simple result and becomes
          something genuinely useful to others.
        </p>
      </article>
    </section>
    <!-- //about me -->
  </div>
  <!-- //page wrapper -->
</RootLayout>
