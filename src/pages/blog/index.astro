---
import GithubIcon from "@/components/icons/GithubIcon.astro";
import MailIcon from "@/components/icons/MailIcon.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<RootLayout>
  <div class="font-custom container mx-auto min-h-dvh px-4 py-24">
    <header class="typo-content">
      <h1>Blog — My Experiments and Logs</h1>
      <div class="mt-6 flex flex-wrap items-center gap-6">
        <p class="grow text-lg!">
          Notes, thoughts, and records of what I build and explore on the web.
        </p>
        <div class="flex gap-4">
          <GithubIcon />
          <MailIcon />
        </div>
      </div>
    </header>

    <section class="mt-16">
      <ul class="space-y-8">
        {
          posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}/`}
                class="border-border hover:bg-muted/40 block rounded-2xl border p-6 transition"
              >
                <div class="typo-content">
                  <h2 class="text-xl! md:text-2xl!">{post.data.title}</h2>
                  <p class="mt-3">{post.data.description}</p>
                  <time class="text-muted-foreground mt-4 block text-sm">
                    {post.data.pubDate.toISOString().slice(0, 10)}
                  </time>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</RootLayout>
