---
import RootLayout from "@/layouts/RootLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<RootLayout>
  <main class="container mx-auto px-4 py-24">
    <section class="typo-content">
      <h1>Blog</h1>
      <p class="mt-6 text-lg!">
        Notes, thoughts, and records of what I build and explore on the web.
      </p>
    </section>

    <section class="mt-16">
      <ul class="space-y-8">
        {
          posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}/`}
                class="border-border hover:bg-muted/40 block rounded-2xl border p-6 transition"
              >
                <div class="typo-content">
                  <h2 class="text-xl! md:text-2xl!">{post.data.title}</h2>
                  <p class="mt-3">{post.data.description}</p>
                  <time class="text-muted-foreground mt-4 block text-sm">
                    {post.data.pubDate.toISOString().slice(0, 10)}
                  </time>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</RootLayout>
