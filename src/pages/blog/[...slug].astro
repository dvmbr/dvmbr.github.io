---
import BlogBreadcrumb from "@/components/blog/BlogBreadcrumb.astro";
import BlogTagBadge from "@/components/blog/BlogTagBadge.astro";
import ScrollProgressBar from "@/components/ui/ScrollProgressBar";
import RootLayout from "@/layouts/RootLayout.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

type BlogPost = CollectionEntry<"blog">;

const { post, posts } = Astro.props as {
  post: BlogPost;
  posts: BlogPost[];
};

const { Content } = await render(post);

const currentIndex = posts.findIndex((item) => item.id === post.id);
const nextPost =
  currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
const previousPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
---

<RootLayout>
  <ScrollProgressBar client:only="react" />
  <div
    class="font-blog container mx-auto min-h-dvh w-full max-w-3xl px-4 py-16 md:py-24"
  >
    <div
      class="border-border/60 bg-muted/40 overflow-hidden rounded-3xl border p-0 shadow-2xl backdrop-blur-lg"
    >
      <header
        class="border-border/30 mb-8 flex flex-col gap-2 border-b px-8 pt-8 pb-6"
      >
        <div class="mb-6">
          <BlogBreadcrumb current={post.data.title} />
        </div>
        <div class="mb-2 flex items-center gap-3">
          <span>
            {post.data.pubDate.toISOString().slice(0, 10)}
          </span>
          {
            Array.isArray((post.data as any).tags) &&
              (post.data as any).tags.length > 0 && (
                <ul class="flex flex-wrap gap-2">
                  {(post.data as any).tags.map((tag: string) => (
                    <li>
                      <BlogTagBadge tag={tag} />
                    </li>
                  ))}
                </ul>
              )
          }
        </div>
        <h1
          class="text-brand-red mb-2 text-3xl leading-tight font-extrabold tracking-tight md:text-4xl"
        >
          {post.data.title}
        </h1>
        <p class="text-muted-foreground mb-1 text-lg leading-relaxed">
          {post.data.description}
        </p>
      </header>

      <article
        class="prose prose-neutral dark:prose-invert prose-headings:font-semibold prose-a:text-brand-mint prose-a:no-underline hover:prose-a:underline prose-strong:text-foreground prose-code:bg-muted prose-code:rounded prose-blockquote:border-l-brand-red prose-blockquote:text-muted-foreground prose-li:marker:text-brand-mint max-w-none px-8 pb-8"
      >
        <Content />

        <div class="mt-8 flex items-center gap-1">
          <Icon class="text-brand-mint text-sm" name="lucide:chevron-left" />
          <a
            href="/blog"
            class="hover:text-brand-mint text-muted-foreground text-xs transition-colors hover:underline"
          >
            Back to blog
          </a>
        </div>
      </article>

      <nav
        class="border-border/30 grid grid-cols-1 gap-4 border-t px-8 py-6 md:grid-cols-2"
      >
        <div>
          {
            previousPost && (
              <a
                href={`/blog/${previousPost.id}`}
                class="group border-border/30 hover:border-brand-mint bg-muted block rounded-xl border p-4 transition hover:shadow-md"
              >
                <span class="group-hover:text-brand-mint text-xs transition-colors">
                  Previous post
                </span>
                <p class="group-hover:text-brand-mint mt-2 line-clamp-1 truncate font-semibold transition-colors">
                  {previousPost.data.title}
                </p>
              </a>
            )
          }
        </div>
        <div class="md:text-right">
          {
            nextPost && (
              <a
                href={`/blog/${nextPost.id}`}
                class="group border-border/30 hover:border-brand-red bg-muted block rounded-xl border p-4 transition hover:shadow-md"
              >
                <span class="group-hover:text-brand-red text-xs transition-colors">
                  Next post
                </span>
                <p class="group-hover:text-brand-red mt-2 line-clamp-1 truncate font-semibold transition-colors">
                  {nextPost.data.title}
                </p>
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </div>
</RootLayout>
