---
import RootLayout from "@/layouts/RootLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

type BlogPost = CollectionEntry<"blog">;

const { post, posts } = Astro.props as {
  post: BlogPost;
  posts: BlogPost[];
};

const { Content } = await render(post);

const currentIndex = posts.findIndex((item) => item.id === post.id);
const previousPost =
  currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
---

<RootLayout>
  <div class="container mx-auto min-h-dvh w-full max-w-3xl px-4 py-16 md:py-24">
    <div
      class="border-border/50 bg-background/60 rounded-2xl border p-6 backdrop-blur md:p-8"
    >
      <header class="border-border/40 font-custom mb-10 border-b pb-6">
        <p class="text-muted-foreground text-sm">
          {post.data.pubDate.toISOString().slice(0, 10)}
        </p>

        <h1 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
          {post.data.title}
        </h1>

        <p class="text-muted-foreground mt-4 text-base leading-relaxed">
          {post.data.description}
        </p>

        {
          Array.isArray((post.data as any).tags) &&
            (post.data as any).tags.length > 0 && (
              <ul class="mt-5 flex flex-wrap gap-2">
                {(post.data as any).tags.map((tag: string) => (
                  <li class="border-border/50 bg-background/50 rounded-full border px-3 py-1 text-xs">
                    #{tag}
                  </li>
                ))}
              </ul>
            )
        }
      </header>

      <article
        class="prose prose-neutral dark:prose-invert prose-headings:font-semibold prose-h2:mt-16 prose-h2:text-2xl prose-p:text-base prose-p:leading-relaxed prose-a:text-brand-mint prose-a:no-underline hover:prose-a:underline prose-strong:text-foreground prose-code:bg-muted prose-code:rounded prose-code:px-1 prose-code:py-0.5 prose-blockquote:border-l-brand-mint prose-blockquote:pl-4 prose-blockquote:text-muted-foreground prose-li:marker:text-muted-foreground font-blog max-w-none"
      >
        <Content />
      </article>

      <nav
        class="border-border/40 mt-12 grid gap-4 border-t pt-6 md:grid-cols-2"
      >
        <div>
          {
            previousPost && (
              <a
                href={`/blog/${previousPost.id}`}
                class="border-border/40 hover:bg-foreground/4 block rounded-xl border p-4 transition"
              >
                <p class="text-muted-foreground text-xs">Previous post</p>
                <p class="mt-2 font-medium">{previousPost.data.title}</p>
              </a>
            )
          }
        </div>

        <div class="md:text-right">
          {
            nextPost && (
              <a
                href={`/blog/${nextPost.id}`}
                class="border-border/40 hover:bg-foreground/4 block rounded-xl border p-4 transition"
              >
                <p class="text-muted-foreground text-xs">Next post</p>
                <p class="mt-2 font-medium">{nextPost.data.title}</p>
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </div>
</RootLayout>
