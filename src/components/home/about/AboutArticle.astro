<style>
  .about-copy {
    position: relative;
    padding-left: 1.25rem;
  }

  .about-copy::before {
    content: "";
    position: absolute;
    top: 0.25rem;
    left: 0;
    width: 1px;
    height: calc(100% - 0.5rem);
    background: color-mix(in srgb, currentColor 12%, transparent);
    opacity: 0.6;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 {
    transition-delay: 0.05s;
  }

  .reveal-delay-2 {
    transition-delay: 0.12s;
  }

  .reveal-delay-3 {
    transition-delay: 0.19s;
  }

  .reveal-delay-4 {
    transition-delay: 0.26s;
  }
</style>

<div class="about-copy space-y-6">
  <article class="mx-auto max-w-5xl space-y-6">
    <p class="reveal reveal-delay-1 text-xl!">
      I am a web developer who enjoys experimenting with ideas and turning them
      into working structures on the web. Through exploring new approaches and
      trying different possibilities, I focus on going beyond simple
      implementation and creating outcomes in my own way.
    </p>

    <p class="reveal reveal-delay-2 text-xl!">
      Rather than just building features, I consider user flows and operational
      contexts to create more stable and maintainable solutions. In live
      services, I have designed and improved web app interfaces around key flows
      such as orders and settlements, continuously refining structures while
      resolving recurring issues.
    </p>

    <p class="reveal reveal-delay-3 text-xl!">
      I have also worked on a variety of projects, including invite-based entry
      systems, dashboards, and automation tools. Across these, I focus not only
      on implementation, but on designing the flow and connections between
      features. Throughout the process, I consistently think about how what I
      build is actually used and what kind of value it creates.
    </p>

    <p class="reveal reveal-delay-4 text-xl!">
      I enjoy experimenting and building my own creations, and I aim to ensure
      that what I create goes beyond a simple result and becomes something
      genuinely useful to others.
    </p>
  </article>
</div>

<script is:inline>
  function initAboutReveal() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.15,
      }
    );

    document.querySelectorAll(".reveal").forEach((element) => {
      observer.observe(element);
    });
  }

  initAboutReveal();
</script>
