---
import { Image } from "astro:assets";
import dvmbrFace from "@/assets/images/dvmbr-face.png";
import { stackCategories } from "@/data/stackIcons";
import GitHubCalendarIsland from "@/components/ui/GitHubCalendarIsland";
import { Badge } from "@/components/ui/badge";
---

<style>
  .gradient-border-wrapper {
    position: relative;
    border-radius: 9999px;
    padding: 4px;
    overflow: hidden;
  }

  /* animated border layer */
  .gradient-border-animated {
    position: absolute;
    inset: 0;
    border-radius: 9999px;

    background: conic-gradient(from 0deg, #ff3131, #67fff0, #ff3131);

    /* 기본은 멈춤 */
    animation: none;

    /* glow */
    box-shadow:
      0 0 12px rgba(255, 49, 49, 0.6),
      0 0 20px rgba(103, 255, 240, 0.6);
  }

  .gradient-border-wrapper .gradient-border-animated {
    animation: rotate-border 4s linear infinite;
  }

  /* 내부 배경 (border 안쪽 정리) */
  .gradient-border-wrapper::before {
    content: "";
    position: absolute;
    inset: 4px;
    background: var(--background);
    border-radius: 9999px;
    z-index: 1;
  }

  @keyframes rotate-border {
    to {
      transform: rotate(360deg);
    }
  }
</style>
<div class="typo-content">
  <section class="flex flex-col items-center gap-10 pt-6 lg:flex-row lg:gap-16">
    <div class="bg-muted relative w-fit rounded-lg p-8">
      <div class="gradient-border-wrapper">
        <div class="gradient-border-animated"></div>

        <Image
          src={dvmbrFace}
          alt="Dvmbr's face"
          class="relative z-10 aspect-square w-40 rounded-full object-cover md:w-72"
        />
      </div>
      <div class="mt-4 w-full">
        <strong class="block text-center text-lg!">DVMBR</strong>
        <p class="mt-4 text-center text-sm!">Web Developer</p>
        <p class="text-center text-sm!">Live in South Korea</p>
      </div>
    </div>

    <article class="min-w-0 flex-1">
      <p class="md:text-lg!">
        Hi! I'm <strong class="text-brand-mint">Dvmbr</strong>, a web developer
        who loves dark mode, minimal yet accented design, and exploring anything
        fun.
      </p>

      <p class="mt-6 md:text-lg!">
        In my free time, I enjoy chatting with friends, listening to music, and
        practicing singing. I also love going for a drive at night or taking a
        walk by the riverside.
      </p>

      <p class="mt-6 md:text-lg!">
        I’ve been working in web development for
        <strong class="text-brand-mint">over 4 years</strong>, giving me a solid
        understanding of how the web works.
      </p>

      <p class="mt-6 md:text-lg!">
        I can build a website from
        <strong class="text-brand-mint">A to Z</strong>. While I'm still
        improving my design skills, I leverage modern tools to create great
        visuals.
      </p>

      <p class="mt-6 md:text-lg!">
        I have experience building real-time data systems using <strong
          class="text-brand-mint">WebSocket</strong
        > and <strong class="text-brand-mint">Socket-based communication</strong
        >, and working with <strong class="text-brand-mint">RESTful APIs</strong
        > to structure data flow between client and server.
        <p class="mt-6 md:text-lg!">
          I’ve also worked on <strong class="text-brand-mint"
            >workflow automation</strong
          > and <strong class="text-brand-mint">state-based UI design</strong> to
          improve usability and maintainability in real services.
        </p>
        <p class="mt-6 md:text-lg!">
          Along the way, I’ve been involved in various parts of the development
          process, including <strong class="text-brand-mint"
            >database modeling</strong
          >, <strong class="text-brand-mint"
            >external service integration</strong
          >, and <strong class="text-brand-mint"
            >setting up deployment environments using CI/CD tools</strong
          >.
        </p>
      </p>

      <p class="mt-6 md:text-lg!">
        Thank you for reading this! If you’d like to know more or just want to
        chat, feel free to contact me.
      </p>
    </article>
    <div></div>
  </section>
  <section class="container mx-auto px-4 py-16">
    <div class="mb-10">
      <h3 class="text-center">My Tech Stack</h3>
    </div>

    <div class="flex flex-col items-center gap-4">
      {
        stackCategories.map((c, i) => (
          <div class="flex flex-wrap justify-center gap-x-6 gap-y-4">
            {c.icons.map((icon) => (
              <div class="border-muted flex items-center gap-1 rounded-full border px-4 py-2">
                <img src={icon.url} alt={icon.alt} class="w-5 md:w-6" />
                <span class="text-sm md:text-base">{icon.name}</span>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </section>
  <section class="container mx-auto px-4 py-16">
    <h3 class="mb-6 text-center text-lg font-semibold">Days I Code</h3>

    <div class="flex">
      <GitHubCalendarIsland
        client:only="react"
        username="dvmbr"
        showWeekdayLabels={true}
        blockSize={20}
        className="mx-auto"
      />
    </div>
  </section>
</div>
